---
import { SITE } from '../config'
import WhatsAppButton from './WhatsAppButton.astro'
---

<section class="hero">
  <div class="container">
    <h1>Drive Your Dream Car Today</h1>
    <p>Premium car leasing with flexible terms, all-inclusive packages, and pan-India delivery.</p>
    <div class="hero-actions">
      <a href="/cars" class="btn btn-primary">Browse Cars</a>
      <WhatsAppButton
        number={SITE.whatsapp}
        text="Hi, I'm interested in leasing a car"
        label="Chat on WhatsApp"
      />
    </div>
  </div>
</section>

<style>
  .hero {
    background: linear-gradient(135deg, #1e3a5f 0%, #2d5a87 100%);
    color: #fff;
    padding: 5rem 0;
    text-align: center;
  }
  h1 {
    font-size: 2.75rem;
    font-weight: 800;
    margin: 0 0 1rem;
    letter-spacing: -0.03em;
    line-height: 1.15;
  }
  .hero p {
    font-size: 1.2rem;
    max-width: 600px;
    margin: 0 auto 2rem;
    line-height: 1.6;
    opacity: 0.9;
  }
  .hero-actions {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
  }
  .btn {
    padding: 0.85rem 2rem;
    border-radius: 8px;
    font-weight: 600;
    font-size: 1rem;
    text-decoration: none;
    transition: all 0.2s;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
  }
  .btn-primary {
    background: #fff;
    color: #1e3a5f;
  }
  .btn-primary:hover {
    background: #f0f4ff;
    transform: translateY(-1px);
  }
  /* WhatsApp button size override for hero context */
  .hero-actions :global(.whatsapp-btn) {
    padding: 0.85rem 2rem;
    font-size: 1rem;
    transform: none;
    transition: background 0.2s, transform 0.2s;
  }
  .hero-actions :global(.whatsapp-btn:hover) {
    transform: translateY(-1px);
  }
  @media (max-width: 640px) {
    .hero { padding: 3rem 0; }
    h1 { font-size: 2rem; }
    .hero p { font-size: 1rem; }
  }
</style>
