---
import type { CollectionEntry } from 'astro:content'
import { formatPrice } from '../utils/formatPrice'

export interface Props {
  car: CollectionEntry<'cars'>
}

const { car } = Astro.props
const { data } = car

const whatsappUrl = `https://wa.me/${data.whatsappNumber.replace(/[^0-9]/g, '')}?text=${encodeURIComponent(data.whatsappText ?? `Hi, I'm interested in leasing the ${data.title}`)}`
---

<article class="card">
  <a href={`/cars/${car.id}`} class="card-image-wrapper">
    <div class="card-image">
      <img src={data.image} alt={data.title} loading="lazy" />
      {data.featured && <span class="badge">Select Fleet</span>}
    </div>
  </a>
  
  <div class="card-body">
    <div class="card-header">
      <a href={`/cars/${car.id}`} class="card-title-link">
        <h3>{data.title}</h3>
      </a>
      <div class="specs">
        <span>{data.year}</span>
        <span class="dot">&bull;</span>
        <span class="spec-text">{data.fuel}</span>
        <span class="dot">&bull;</span>
        <span class="spec-text">{data.transmission}</span>
        <span class="dot">&bull;</span>
        <span>{data.seats} Seats</span>
      </div>
    </div>
    
    <div class="card-footer">
      <div class="card-pricing">
        {data.wasPrice && <span class="was">{formatPrice(data.wasPrice)}</span>}
        <div class="price">
          <span class="current">{formatPrice(data.price)}</span>
          <span class="per">/ month</span>
        </div>
      </div>
      
      <div class="card-actions">
        <a href={`/cars/${car.id}`} class="action-btn btn-specs">Specs</a>
        <a href={whatsappUrl} target="_blank" rel="noopener noreferrer" class="action-btn btn-inquire">Inquire</a>
      </div>
    </div>
  </div>
</article>

<style>
  .card {
    background: transparent;
    border: none;
    display: flex;
    flex-direction: column;
    transition: transform var(--transition);
  }
  
  .card-image-wrapper {
    display: block;
    width: 100%;
    border: 1px solid var(--border-hairline);
    padding: 1rem;
    background: var(--bg-secondary);
    transition: border-color var(--transition);
  }
  
  .card:hover .card-image-wrapper {
    border-color: var(--text-primary);
  }
  
  .card-image {
    position: relative;
    aspect-ratio: 16 / 10;
    overflow: hidden;
    background: #e5dfd5;
  }
  
  .card-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s cubic-bezier(0.25, 1, 0.5, 1);
  }
  
  .card:hover .card-image img {
    transform: scale(1.05);
  }
  
  .badge {
    position: absolute;
    top: 0.75rem;
    left: 0.75rem;
    background: var(--text-primary);
    color: var(--white);
    font-family: var(--font-sans);
    font-size: 0.65rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    padding: 0.25rem 0.6rem;
    border-radius: var(--radius-sm);
  }
  
  .card-body {
    padding: 1.25rem 0 0;
    display: flex;
    flex-direction: column;
    flex: 1;
  }
  
  .card-header {
    margin-bottom: 1rem;
  }
  
  .card-title-link {
    display: inline-block;
  }
  
  .card-header h3 {
    font-family: var(--font-sans);
    font-size: 1.15rem;
    font-weight: 700;
    margin: 0 0 0.4rem;
    color: var(--text-primary);
    line-height: 1.2;
    transition: color var(--transition);
  }
  
  .card-header h3:hover {
    color: var(--accent-gold-dark);
  }
  
  .specs {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.4rem;
    font-family: var(--font-sans);
    font-size: 0.75rem;
    color: var(--text-secondary);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  
  .spec-text {
    text-transform: capitalize;
  }
  
  .dot {
    color: var(--accent-gold);
    font-size: 0.8rem;
  }
  
  .card-footer {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    margin-top: auto;
    border-top: 1px solid var(--border-hairline);
    padding-top: 1.25rem;
  }
  
  .card-pricing {
    display: flex;
    flex-direction: column;
  }
  
  .was {
    font-family: var(--font-sans);
    font-size: 0.75rem;
    color: var(--muted);
    text-decoration: line-through;
    margin-bottom: 0.1rem;
  }
  
  .price {
    display: flex;
    align-items: baseline;
    gap: 0.25rem;
  }
  
  .current {
    font-family: var(--font-sans);
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--text-primary);
    letter-spacing: -0.01em;
  }
  
  .per {
    font-family: var(--font-sans);
    font-size: 0.75rem;
    color: var(--text-secondary);
    font-weight: 400;
  }
  
  .card-actions {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.5rem;
    width: 100%;
  }
  
  .action-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-sans);
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    padding: 0.75rem 1rem;
    transition: all var(--transition);
    text-decoration: none;
    text-align: center;
    border-radius: var(--radius-sm);
  }
  
  .btn-specs {
    background: var(--text-primary);
    color: var(--white);
    border: 1px solid var(--text-primary);
  }
  
  .btn-specs:hover {
    background: var(--accent-gold);
    border-color: var(--accent-gold);
  }
  
  .btn-inquire {
    background: var(--whatsapp-green);
    color: var(--white);
    border: 1px solid var(--whatsapp-green);
  }
  
  .btn-inquire:hover {
    background: var(--whatsapp-green-hover);
    border-color: var(--whatsapp-green-hover);
    transform: translateY(-1px);
  }
</style>
