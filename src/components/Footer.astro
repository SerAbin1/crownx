---
import { SITE } from '../config'
import { getEntry } from 'astro:content'

const homePage = await getEntry('pages', 'home')
const logoImage = homePage?.data.logoImage
---

<footer class="footer">
  <div class="container">
    <div class="footer-grid">
      <div class="footer-brand">
        <div class="footer-logo">
          {logoImage ? (
            <img src={logoImage} alt="CrownX Logo" class="logo-img" />
          ) : (
            <>
              <span class="logo-icon">&#8226;</span>
              CrownX
            </>
          )}
        </div>
        <p class="brand-desc">Everyday car leasing marketplace in India. Connecting lessors with lessees to make vehicle leasing simple, flexible, and accessible for everyone.</p>
      </div>
      
      <div class="footer-col">
        <h4>Explore</h4>
        <ul>
          <li><a href="/">Home</a></li>
          <li><a href="/cars">Browse Cars</a></li>
          <li><a href="/about">About Us</a></li>
          <li><a href="/contact">Contact</a></li>
        </ul>
      </div>
      
      <div class="footer-col">
        <h4>Connect</h4>
        <ul>
          <li><a href={`https://wa.me/${SITE.whatsapp}`} target="_blank" rel="noopener noreferrer">{SITE.whatsapp}</a></li>
          <li><a href={`mailto:${SITE.email}`}>{SITE.email}</a></li>
          <li><span class="address-span">{SITE.address}</span></li>
        </ul>
      </div>
      
      <div class="footer-col">
        <h4>Follow</h4>
        <ul>
          <li><a href={`https://wa.me/${SITE.whatsapp}`} target="_blank" rel="noopener noreferrer" class="social-link">WhatsApp</a></li>
        </ul>
      </div>
    </div>
    
    <div class="footer-bottom">
      <p>&copy; {new Date().getFullYear()} {SITE.name}. All rights reserved.</p>
    </div>
  </div>
</footer>

<style>
  .footer {
    background: var(--text-primary);
    color: var(--muted);
    padding: 6rem 0 2rem;
    border-top: 1px solid var(--border-hairline);
  }
  
  .footer-grid {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr 1fr;
    gap: 4rem;
    margin-bottom: 5rem;
  }
  
  .footer-logo {
    font-family: var(--font-sans);
    font-size: 1.35rem;
    font-weight: 700;
    color: var(--bg-primary);
    margin-bottom: 1.25rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  
  .footer-logo .logo-img {
    height: 32px;
    width: auto;
    object-fit: contain;
    display: block;
    filter: brightness(0) invert(1);
  }
  
  .logo-icon {
    color: var(--accent-gold);
    font-size: 1.5rem;
    line-height: 1;
  }
  
  .brand-desc {
    font-family: var(--font-sans);
    font-size: 0.85rem;
    line-height: 1.7;
    color: #a3a19a;
    max-width: 320px;
    margin: 0;
  }
  
  .footer h4 {
    font-family: var(--font-sans);
    color: var(--bg-primary);
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    margin: 0 0 1.5rem;
  }
  
  .footer ul {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  
  .footer li {
    margin-bottom: 0.75rem;
    font-family: var(--font-sans);
    font-size: 0.85rem;
  }
  
  .footer a {
    color: #a3a19a;
    text-decoration: none;
    transition: color var(--transition);
  }
  
  .footer a:hover {
    color: var(--accent-gold);
  }
  
  .address-span {
    color: #8a8882;
    display: inline-block;
    line-height: 1.5;
  }
  
  .footer-bottom {
    border-top: 1px solid rgba(250, 249, 245, 0.08);
    padding-top: 2rem;
    text-align: center;
  }
  
  .footer-bottom p {
    font-family: var(--font-sans);
    font-size: 0.75rem;
    color: #686762;
    margin: 0;
  }
  
  @media (max-width: 1024px) {
    .footer-grid {
      gap: 2.5rem;
    }
  }
  
  @media (max-width: 768px) {
    .footer-grid {
      grid-template-columns: 1fr;
      gap: 3rem;
      margin-bottom: 3.5rem;
    }
    .footer {
      padding: 4rem 0 2rem;
    }
  }
</style>
