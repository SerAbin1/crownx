---
import Base from '../layouts/Base.astro'
import WhatsAppButton from '../components/WhatsAppButton.astro'
import { SITE } from '../config'
import { getPage } from '../utils/getPage'

const { page, Content } = await getPage('contact')
---

{page && Content ? (
  <Base title={page.data.title}>
    <section class="page-section">
      <div class="container">
        <h1 class="page-title">{page.data.title}</h1>
        <div class="contact-layout">
          <div class="prose"><Content /></div>
          <div class="contact-whatsapp">
            <h3>Chat with Us</h3>
            <p>Get an instant response from our team on WhatsApp.</p>
            <WhatsAppButton
              number={SITE.whatsapp}
              text="Hi, I'd like to inquire about car leasing"
              label="Start WhatsApp Chat"
            />
          </div>
        </div>
      </div>
    </section>
  </Base>
) : (
  <Base title="Contact Us">
    <div class="container page-section"><p>Page not found.</p></div>
  </Base>
)}

<style>
  .contact-layout {
    display: grid;
    grid-template-columns: 1fr 320px;
    gap: 2rem;
    align-items: start;
  }
  .contact-whatsapp {
    background: #f0faf0;
    border: 1px solid #bbf7d0;
    border-radius: 12px;
    padding: 1.5rem;
    text-align: center;
  }
  .contact-whatsapp h3 {
    margin: 0 0 0.5rem;
    font-size: 1.15rem;
    color: #166534;
  }
  .contact-whatsapp p {
    margin: 0 0 1rem;
    font-size: 0.9rem;
    color: #15803d;
  }
  @media (max-width: 768px) {
    .contact-layout {
      grid-template-columns: 1fr;
    }
  }
</style>
