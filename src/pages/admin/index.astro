<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Admin - CrownX Leasing</title>
</head>
<body>
  <div id="root">
    <div class="loading">Loading...</div>
  </div>
</body>
</html>

<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  body {
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
    background: #f1f5f9;
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  #root { width: 100%; }
  .loading {
    text-align: center;
    color: #64748b;
    font-size: 1.1rem;
    padding: 3rem;
  }
  .error {
    color: #dc2626;
    text-align: center;
    margin-top: 0.75rem;
    font-size: 0.9rem;
  }
  .login-card {
    background: #fff;
    border-radius: 12px;
    padding: 2.5rem;
    width: 400px;
    max-width: 94vw;
    margin: 2rem auto;
    box-shadow: 0 4px 24px rgba(0,0,0,.08);
  }
  .login-card h1 {
    font-size: 1.5rem;
    font-weight: 800;
    color: #1e3a5f;
    text-align: center;
    margin-bottom: 0.25rem;
  }
  .login-card .subtitle {
    text-align: center;
    color: #94a3b8;
    font-size: 0.9rem;
    margin-bottom: 1.75rem;
  }
  .login-card label {
    display: block;
    font-size: 0.85rem;
    font-weight: 600;
    color: #334155;
    margin-bottom: 0.25rem;
  }
  .login-card input {
    width: 100%;
    padding: 0.65rem 0.75rem;
    border: 1px solid #cbd5e1;
    border-radius: 6px;
    font-size: 0.95rem;
    margin-bottom: 1rem;
    outline: none;
    transition: border-color .15s;
  }
  .login-card input:focus { border-color: #1e3a5f; }
  .login-card button {
    width: 100%;
    padding: 0.75rem;
    background: #1e3a5f;
    color: #fff;
    border: none;
    border-radius: 6px;
    font-size: 1rem;
    font-weight: 600;
    cursor: pointer;
    transition: background .15s;
  }
  .login-card button:hover { background: #2d4a6f; }
  .login-card button:disabled { opacity: .6; cursor: not-allowed; }
</style>

<script>
  import { login, getUser, logout, handleAuthCallback } from '@netlify/identity'

  const root = document.getElementById('root')

  async function init() {
    const hash = location.hash

    if (hash && (hash.includes('invite_token') || hash.includes('confirmation_token') || hash.includes('recovery_token'))) {
      root.innerHTML = '<div class="loading">Processing authentication...</div>'
      try {
        const result = await handleAuthCallback()
        if (result) {
          const next = await loadCMS()
          if (next) return
        }
      } catch (e) {
        root.innerHTML = `<div class="error">Authentication failed: ${e.message}</div>`
        return
      }
    }

    try {
      const user = await getUser()
      if (user && user.token?.access_token) {
        const next = await loadCMS()
        if (next) return
      }
    } catch {}

    showLogin()
  }

  function showLogin(errorMsg) {
    root.innerHTML = `
      <div class="login-card">
        <h1>CrownX Leasing</h1>
        <p class="subtitle">Admin Panel</p>
        <form id="login-form">
          <label>Email
            <input type="email" name="email" required autocomplete="email" />
          </label>
          <label>Password
            <input type="password" name="password" required autocomplete="current-password" />
          </label>
          <button type="submit" id="login-btn">Log In</button>
          <p id="login-error" class="error">${errorMsg || ''}</p>
        </form>
      </div>
    `

    document.getElementById('login-form').addEventListener('submit', async (e) => {
      e.preventDefault()
      const btn = document.getElementById('login-btn')
      const err = document.getElementById('login-error')
      btn.disabled = true
      btn.textContent = 'Logging in...'
      try {
        await login(e.target.email.value, e.target.password.value)
        const next = await loadCMS()
        if (!next) showLogin('Failed to load CMS')
      } catch (ex) {
        btn.disabled = false
        btn.textContent = 'Log In'
        err.textContent = ex.message || 'Invalid email or password'
      }
    })
  }

  async function loadCMS() {
    root.innerHTML = '<div class="loading">Loading content manager...</div>'

    try {
      const user = await getUser()
      if (!user) { showLogin('Session expired. Please log in again.'); return false }

      window.CMS_MANUAL_INIT = true

      window.netlifyIdentity = {
        currentUser: () => user ? {
          id: user.id,
          email: user.email,
          jwt: async () => {
            const fresh = await getUser()
            return fresh?.token?.access_token
          },
        } : null,
        on: () => {},
      }

      const CMS = (await import('decap-cms-app')).default

      const logoutBtn = document.createElement('div')
      logoutBtn.style.cssText = 'position:fixed;top:12px;right:12px;z-index:9999'
      logoutBtn.innerHTML = `<button style="padding:6px 14px;border:1px solid #e2e8f0;border-radius:6px;background:#fff;cursor:pointer;font-size:.85rem">Logout</button>`
      logoutBtn.querySelector('button').onclick = async () => {
        await logout()
        logoutBtn.remove()
        showLogin()
      }
      document.body.appendChild(logoutBtn)

      CMS.init({
        config: {
          backend: {
            name: 'git-gateway',
            branch: 'main',
          },
          media_folder: 'public/images',
          public_folder: '/images',
          collections: [
            {
              name: 'cars',
              label: 'Cars',
              label_singular: 'Car',
              folder: 'src/content/cars',
              create: true,
              delete: true,
              format: 'frontmatter',
              slug: '{{slug}}',
              preview_path: 'cars/{{slug}}',
              fields: [
                { label: 'Title', name: 'title', widget: 'string' },
                { label: 'Year', name: 'year', widget: 'number', value_type: 'int', min: 2000, max: 2030 },
                { label: 'Monthly Price (₹)', name: 'price', widget: 'number' },
                { label: 'Was Price (₹)', name: 'wasPrice', widget: 'number', required: false },
                { label: 'Brand', name: 'brand', widget: 'string' },
                { label: 'Model', name: 'model', widget: 'string' },
                { label: 'Main Image', name: 'image', widget: 'image' },
                { label: 'Gallery', name: 'gallery', widget: 'image', multiple: true, required: false },
                { label: 'Fuel Type', name: 'fuel', widget: 'select', options: ['petrol', 'diesel', 'electric', 'hybrid'] },
                { label: 'Transmission', name: 'transmission', widget: 'select', options: ['auto', 'manual'] },
                { label: 'Seats', name: 'seats', widget: 'number', value_type: 'int', min: 2, max: 9 },
                { label: 'WhatsApp Number', name: 'whatsappNumber', widget: 'string' },
                { label: 'WhatsApp Message', name: 'whatsappText', widget: 'string', required: false },
                { label: 'Featured', name: 'featured', widget: 'boolean', default: false, required: false },
                { label: 'Display Order', name: 'order', widget: 'number', default: 0, required: false },
                { label: 'Description', name: 'body', widget: 'markdown' },
              ],
            },
            {
              name: 'pages',
              label: 'Pages',
              folder: 'src/content/pages',
              create: true,
              delete: false,
              format: 'frontmatter',
              slug: '{{slug}}',
              fields: [
                { label: 'Title', name: 'title', widget: 'string' },
                { label: 'Order', name: 'order', widget: 'number', default: 0, required: false },
                { label: 'Body', name: 'body', widget: 'markdown' },
              ],
            },
          ],
        },
      })

      return true
    } catch (e) {
      console.error('CMS load error:', e)
      showLogin(`Failed to load CMS: ${e.message}`)
      return false
    }
  }

  init()
</script>
