---
import Base from '../../layouts/Base.astro'
import CarGrid from '../../components/CarGrid.astro'
import { getCollection } from 'astro:content'

const allCars = await getCollection('cars')
const sorted = allCars.sort((a, b) => a.data.order - b.data.order)
const totalCount = sorted.length
---

<Base title="Browse Cars" description="Browse everyday vehicles available for lease from independent lessors across India on the CrownX marketplace.">
  <!-- Page Hero Banner -->
  <section class="fleet-hero">
    <div class="container">
      <div class="fleet-hero-inner">
        <span class="hero-kicker">The Collection</span>
        <h1>Available <span class="gold">Cars</span></h1>
        <p class="hero-lead">
          Normal, everyday use vehicles listed by lessors near you. Browse, compare, and connect to find the perfect car for your daily needs.
        </p>
        <div class="hero-meta">
          <span class="meta-item">{totalCount} Cars Listed</span>
          <span class="meta-sep">&mdash;</span>
          <span class="meta-item">Verified Owners</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Fleet Grid -->
  <section class="fleet-grid-section">
    <div class="container">
      {
        sorted.length > 0
          ? <CarGrid cars={sorted} />
          : (
            <div class="empty">
              <h2>Listings Coming Soon</h2>
              <p>Cars are being verified and listed. Reach out to us directly if you want to list your car or find early access vehicles.</p>
              <a href="/contact" class="btn btn-outline">Get In Touch</a>
            </div>
          )
      }
    </div>
  </section>
</Base>

<style>
  .fleet-hero {
    padding: 6rem 0 5rem;
    border-bottom: 1px solid var(--border-hairline);
    background: var(--bg-primary);
  }

  .fleet-hero-inner {
    max-width: 720px;
  }

  .hero-kicker {
    font-family: var(--font-sans);
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: var(--accent-gold);
    display: block;
    margin-bottom: 1.25rem;
  }

  .fleet-hero h1 {
    font-family: var(--font-sans);
    font-size: 3.75rem;
    font-weight: 800;
    line-height: 1.08;
    margin: 0 0 1.5rem;
    color: var(--text-primary);
    letter-spacing: -0.03em;
  }

  .fleet-hero h1 .gold {
    color: var(--accent-gold);
  }

  .hero-lead {
    font-family: var(--font-sans);
    font-size: 1.05rem;
    line-height: 1.75;
    color: var(--text-secondary);
    margin: 0 0 2rem;
    max-width: 560px;
  }

  .hero-meta {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-family: var(--font-sans);
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--muted);
  }

  .meta-sep {
    color: var(--accent-gold);
  }

  .fleet-grid-section {
    padding: 6rem 0 8rem;
  }

  .empty {
    text-align: center;
    padding: 6rem 0;
    max-width: 480px;
    margin: 0 auto;
  }

  .empty h2 {
    font-family: var(--font-sans);
    font-size: 2rem;
    font-weight: 700;
    color: var(--text-primary);
    margin: 0 0 1rem;
  }

  .empty p {
    font-family: var(--font-sans);
    font-size: 1rem;
    color: var(--text-secondary);
    line-height: 1.7;
    margin: 0 0 2.5rem;
  }

  @media (max-width: 768px) {
    .fleet-hero {
      padding: 4rem 0 3.5rem;
    }
    .fleet-hero h1 {
      font-size: 2.75rem;
    }
    .fleet-grid-section {
      padding: 4rem 0 5rem;
    }
  }
</style>
