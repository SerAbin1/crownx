---
import Base from '../../layouts/Base.astro'
import CarGrid from '../../components/CarGrid.astro'
import { getCollection } from 'astro:content'

const allCars = await getCollection('cars')
const sorted = allCars.sort((a, b) => a.data.order - b.data.order)
---

<Base title="Our Cars">
  <section class="page-section">
    <div class="container">
      <h1 class="page-title">Our Fleet</h1>
      <p class="page-subtitle">Choose from a wide range of premium vehicles</p>
      {
        sorted.length > 0
          ? <CarGrid cars={sorted} />
          : (
            <div class="empty">
              <p>No cars available right now. Check back soon or contact us for more information.</p>
              <a href="/contact" class="btn">Contact Us</a>
            </div>
          )
      }
    </div>
  </section>
</Base>

<style>
  .page-subtitle {
    color: #6b7280;
    margin: 0 0 2rem;
    font-size: 1.1rem;
  }
  .empty {
    text-align: center;
    padding: 4rem 0;
    color: #6b7280;
  }
  .empty p {
    margin-bottom: 1.5rem;
  }
  .btn {
    display: inline-block;
    padding: 0.75rem 1.75rem;
    background: #1e3a5f;
    color: #fff;
    text-decoration: none;
    border-radius: 8px;
    font-weight: 600;
  }
</style>
