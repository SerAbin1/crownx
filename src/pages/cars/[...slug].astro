---
import Base from '../../layouts/Base.astro'
import WhatsAppButton from '../../components/WhatsAppButton.tsx'
import { getCollection, render } from 'astro:content'

export async function getStaticPaths() {
  const cars = await getCollection('cars')
  return cars.map((car) => ({
    params: { slug: car.id },
    props: { car },
  }))
}

const { car } = Astro.props
const { Content } = await render(car)
const { data } = car

const formatPrice = (price: number) =>
  new Intl.NumberFormat('en-IN', { style: 'currency', currency: 'INR', maximumFractionDigits: 0 }).format(price)
---

<Base title={data.title}>
  <section class="page-section">
    <div class="container detail-layout">
      <div class="gallery">
        <img src={data.image} alt={data.title} class="main-image" />
        {data.gallery && data.gallery.length > 0 && (
          <div class="thumbnails">
            {data.gallery.map((img) => <img src={img} alt="" />)}
          </div>
        )}
      </div>
      <div class="info">
        <h1 class="title">{data.title}</h1>
        <div class="specs">
          <div class="spec"><span class="label">Year</span><span>{data.year}</span></div>
          <div class="spec"><span class="label">Fuel</span><span class="cap">{data.fuel}</span></div>
          <div class="spec"><span class="label">Transmission</span><span class="cap">{data.transmission}</span></div>
          <div class="spec"><span class="label">Seats</span><span>{data.seats}</span></div>
        </div>
        <div class="pricing">
          {data.wasPrice && <span class="was-price">{formatPrice(data.wasPrice)}</span>}
          <div class="current-price">
            <span class="amount">{formatPrice(data.price)}</span>
            <span class="per">/month</span>
          </div>
          <p class="include">Insurance, registration & maintenance included</p>
        </div>
        <div class="actions">
          <WhatsAppButton
            number={data.whatsappNumber}
            text={data.whatsappText}
            label="Inquire on WhatsApp"
          />
        </div>
        <div class="description prose">
          <Content />
        </div>
      </div>
    </div>
  </section>
</Base>

<style>
  .detail-layout {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
    align-items: start;
  }
  .gallery {
    position: sticky;
    top: 80px;
  }
  .main-image {
    width: 100%;
    aspect-ratio: 16 / 10;
    object-fit: cover;
    border-radius: 12px;
    background: #f3f4f6;
  }
  .thumbnails {
    display: flex;
    gap: 0.5rem;
    margin-top: 0.75rem;
  }
  .thumbnails img {
    width: 80px;
    height: 60px;
    object-fit: cover;
    border-radius: 6px;
    cursor: pointer;
    border: 2px solid transparent;
    transition: border-color 0.15s;
  }
  .thumbnails img:hover {
    border-color: #1e3a5f;
  }
  .title {
    font-size: 2rem;
    font-weight: 800;
    color: #111827;
    margin: 0 0 1.5rem;
  }
  .specs {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.75rem;
    margin-bottom: 1.5rem;
  }
  .spec {
    background: #f3f4f6;
    padding: 0.65rem 1rem;
    border-radius: 8px;
    display: flex;
    justify-content: space-between;
    font-size: 0.9rem;
  }
  .label {
    color: #6b7280;
    font-weight: 500;
  }
  .cap { text-transform: capitalize; }
  .pricing {
    margin-bottom: 1.5rem;
    padding: 1.25rem;
    background: #f0faf0;
    border: 1px solid #bbf7d0;
    border-radius: 10px;
  }
  .was-price {
    display: block;
    text-decoration: line-through;
    color: #9ca3af;
    font-size: 1rem;
    margin-bottom: 0.25rem;
  }
  .current-price {
    display: flex;
    align-items: baseline;
    gap: 0.4rem;
  }
  .amount {
    font-size: 2.25rem;
    font-weight: 800;
    color: #166534;
  }
  .per {
    font-size: 1rem;
    color: #15803d;
    font-weight: 500;
  }
  .include {
    margin: 0.5rem 0 0;
    font-size: 0.85rem;
    color: #15803d;
  }
  .actions :global(.whatsapp-btn) {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background: #25D366;
    color: #fff;
    padding: 0.85rem 2rem;
    border-radius: 8px;
    font-weight: 600;
    font-size: 1rem;
    text-decoration: none;
    transition: background 0.15s;
  }
  .actions :global(.whatsapp-btn:hover) {
    background: #20bd5a;
  }
  .description {
    margin-top: 2rem;
  }
  @media (max-width: 768px) {
    .detail-layout {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }
    .gallery { position: static; }
  }
</style>

<script>
  document.querySelectorAll('.thumbnails img')?.forEach((thumb) => {
    thumb.addEventListener('click', () => {
      const main = document.querySelector('.main-image')
      if (main) {
        const tmp = main.getAttribute('src')
        main.setAttribute('src', thumb.getAttribute('src'))
        thumb.setAttribute('src', tmp)
      }
    })
  })
</script>
