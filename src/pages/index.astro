---
import Base from '../layouts/Base.astro'
import Hero from '../components/Hero.astro'
import CarGrid from '../components/CarGrid.astro'
import WhatsAppButton from '../components/WhatsAppButton.astro'
import { SITE } from '../config'
import { getCollection, getEntry } from 'astro:content'

const allCars = await getCollection('cars')
const featured = allCars
  .filter((car) => car.data.featured)
  .sort((a, b) => a.data.order - b.data.order)

const homePage = await getEntry('pages', 'home')
---

<Base title="Home">
  <Hero
    titleLine1={homePage?.data.heroTitleLine1}
    titleLine2={homePage?.data.heroTitleLine2}
    description={homePage?.data.heroDescription}
  />

  <!-- Brand Philosophy Section -->
  <section class="philosophy-section reveal">
    <div class="container">
      <div class="philosophy-grid">
        <div class="philosophy-manifesto">
          <span class="sub-label">Our Philosophy</span>
          <h2>A lease shouldn't limit you.<br/><span class="gold">It should liberate you.</span></h2>
          <p class="manifesto-lead">
            We are redefining everyday car leasing in India. By directly connecting vehicle owners (lessors) with everyday drivers (lessees), CrownX makes vehicle leasing simple, affordable, and accessible to everyone.
          </p>
        </div>
        
        <div class="philosophy-pillars">
          <div class="pillar-row">
            <span class="pillar-num">01 /</span>
            <div class="pillar-content">
              <h3>Connect Lessors & Lessees</h3>
              <p>We don't own a fleet. We connect trusted vehicle owners with verified lessees, offering a diverse selection of everyday cars for your regular needs.</p>
            </div>
          </div>
          
          <div class="pillar-row">
            <span class="pillar-num">02 /</span>
            <div class="pillar-content">
              <h3>Flexible Terms</h3>
              <p>Select lease periods and mileage plans that fit your daily commute, family road trips, or business needs, directly negotiated with lessors.</p>
            </div>
          </div>
          
          <div class="pillar-row">
            <span class="pillar-num">03 /</span>
            <div class="pillar-content">
              <h3>Turnkey Simplicity</h3>
              <p>With maintenance guidance, insurance arrangements, and transparent agreements, leasing a normal everyday vehicle is as hassle-free as it gets.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Featured Vehicles Section -->
  <section class="page-section reveal">
    <div class="container">
      <div class="section-header">
        <span class="section-subtitle">Available Cars</span>
        <h2 class="section-title">Featured <span class="gold">Vehicles</span></h2>
      </div>
      {
        featured.length > 0
          ? <CarGrid cars={featured} />
          : <p style="text-align:center;color:var(--muted);font-size:1.1rem;padding:3rem 0;">No featured cars yet. Check back soon.</p>
      }
    </div>
  </section>

  <!-- High-end Quote Banner -->
  <section class="quote-section reveal">
    <div class="container">
      <div class="quote-wrapper">
        <blockquote>
          "Simplicity is the ultimate sophistication."
        </blockquote>
        <cite>— Leonardo da Vinci</cite>
      </div>
    </div>
  </section>

  <!-- Call to Action Section -->
  <section class="cta-section reveal">
    <div class="container">
      <div class="cta-grid">
        <div class="cta-text">
          <span class="cta-kicker">Tailored Solutions</span>
          <h2>Ready to <span class="gold">get started?</span></h2>
          <p>Ready to list your car as a lessor or find your next ride as a lessee? Start browsing listings or get in touch with our team to learn more.</p>
        </div>
        <div class="cta-actions">
          <a href="/cars" class="btn btn-outline">Browse Cars</a>
          <WhatsAppButton
            number={SITE.whatsapp}
            text="Hi, I'd like to tailor a lease package with CrownX"
            label="Inquire via WhatsApp"
          />
        </div>
      </div>
    </div>
  </section>
</Base>

<style>
  /* Philosophy Manifesto */
  .philosophy-section {
    padding: 8rem 0;
    background: var(--bg-secondary);
    border-bottom: 1px solid var(--border-hairline);
  }
  
  .philosophy-grid {
    display: grid;
    grid-template-columns: 1.1fr 0.9fr;
    gap: 5rem;
    align-items: flex-start;
  }
  
  .sub-label {
    font-family: var(--font-sans);
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--accent-gold);
    display: block;
    margin-bottom: 1.5rem;
  }
  
  .philosophy-manifesto h2 {
    font-family: var(--font-sans);
    font-size: 2.75rem;
    font-weight: 700;
    line-height: 1.15;
    margin: 0 0 2rem;
    color: var(--text-primary);
    letter-spacing: -0.02em;
  }
  
  .philosophy-manifesto h2 .gold {
    color: var(--accent-gold);
  }
  
  .manifesto-lead {
    font-family: var(--font-sans);
    font-size: 1.1rem;
    line-height: 1.8;
    color: var(--text-secondary);
    max-width: 580px;
    margin: 0;
  }
  
  .philosophy-pillars {
    display: flex;
    flex-direction: column;
    gap: 3rem;
  }
  
  .pillar-row {
    display: flex;
    gap: 1.5rem;
    align-items: flex-start;
  }
  
  .pillar-num {
    font-family: var(--font-sans);
    font-size: 0.85rem;
    font-weight: 700;
    color: var(--accent-gold);
  }
  
  .pillar-content h3 {
    font-family: var(--font-sans);
    font-size: 1.15rem;
    font-weight: 700;
    margin: 0 0 0.5rem;
    color: var(--text-primary);
  }
  
  .pillar-content p {
    font-family: var(--font-sans);
    font-size: 0.9rem;
    line-height: 1.6;
    color: var(--text-secondary);
    margin: 0;
  }
  
  /* Section Header */
  .section-header {
    margin-bottom: 5rem;
  }
  
  .section-header .section-subtitle {
    margin-bottom: 0.75rem;
  }
  
  .section-header .section-title {
    margin-bottom: 0;
  }
  
  /* Quote banner */
  .quote-section {
    padding: 8rem 0;
    text-align: center;
    background: var(--bg-primary);
    border-bottom: 1px solid var(--border-hairline);
  }
  
  .quote-wrapper {
    max-width: 800px;
    margin: 0 auto;
  }
  
  .quote-wrapper blockquote {
    font-family: var(--font-sans);
    font-size: 2rem;
    font-style: normal;
    font-weight: 600;
    margin: 0 0 1.5rem;
    color: var(--text-primary);
    line-height: 1.35;
  }
  
  .quote-wrapper cite {
    font-family: var(--font-sans);
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    font-style: normal;
    color: var(--accent-gold-dark);
    font-weight: 600;
  }
  
  /* Call To Action */
  .cta-section {
    position: relative;
    background: var(--bg-secondary);
    padding: 8rem 0;
  }
  
  .cta-grid {
    display: grid;
    grid-template-columns: 1.1fr 0.9fr;
    gap: 4rem;
    align-items: center;
  }
  
  .cta-text {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
  }
  
  .cta-kicker {
    font-family: var(--font-sans);
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--accent-gold);
    margin-bottom: 1.5rem;
  }
  
  .cta-text h2 {
    font-family: var(--font-sans);
    font-size: 2.75rem;
    font-weight: 700;
    margin: 0 0 1.5rem;
    line-height: 1.15;
    color: var(--text-primary);
    letter-spacing: -0.02em;
  }
  
  .cta-text h2 .gold {
    color: var(--accent-gold);
  }
  
  .cta-text p {
    font-family: var(--font-sans);
    font-size: 1rem;
    line-height: 1.7;
    color: var(--text-secondary);
    margin: 0;
    max-width: 540px;
  }
  
  .cta-actions {
    display: flex;
    gap: 1.25rem;
    justify-content: flex-start;
    align-items: center;
    flex-wrap: wrap;
  }
  
  @media (max-width: 1024px) {
    .philosophy-grid, .cta-grid {
      gap: 3rem;
    }
    .philosophy-manifesto h2, .cta-text h2 {
      font-size: 2.25rem;
    }
  }
  
  @media (max-width: 768px) {
    .philosophy-section, .quote-section, .cta-section {
      padding: 5rem 0;
    }
    
    .philosophy-grid, .cta-grid {
      grid-template-columns: 1fr;
      gap: 4rem;
    }
    
    .philosophy-manifesto h2, .cta-text h2 {
      font-size: 2rem;
      margin-bottom: 1.5rem;
    }
    
    .quote-wrapper blockquote {
      font-size: 1.5rem;
    }
    
    .section-header {
      margin-bottom: 3.5rem;
    }
  }
</style>
