---
import Base from '../layouts/Base.astro'
import Hero from '../components/Hero.astro'
import CarGrid from '../components/CarGrid.astro'
import WhatsAppButton from '../components/WhatsAppButton.tsx'
import { getCollection } from 'astro:content'

const allCars = await getCollection('cars')
const featured = allCars
  .filter((car) => car.data.featured)
  .sort((a, b) => a.data.order - b.data.order)
---

<Base title="Home">
  <Hero />

  <section class="page-section">
    <div class="container">
      <h2 class="section-title">Featured Vehicles</h2>
      <p class="section-subtitle">Our handpicked selection of premium lease deals</p>
      {
        featured.length > 0
          ? <CarGrid cars={featured} />
          : <p style="text-align:center;color:#9ca3af;">No featured cars yet. Check back soon.</p>
      }
    </div>
  </section>

  <section class="cta-section">
    <div class="container">
      <h2>Ready to Get Behind the Wheel?</h2>
      <p>Contact us today and find the perfect lease plan for your lifestyle.</p>
      <div class="cta-actions">
        <a href="/cars" class="btn-primary">View All Cars</a>
        <WhatsAppButton
          number="919999999999"
          text="Hi, I'd like to know more about leasing a car with CrownX"
          label="Chat on WhatsApp"
        />
      </div>
    </div>
  </section>
</Base>

<style>
  .cta-section {
    background: linear-gradient(135deg, #1e3a5f 0%, #2d5a87 100%);
    color: #fff;
    padding: 4rem 0;
    text-align: center;
    margin-top: 2rem;
  }
  .cta-section h2 {
    font-size: 2rem;
    font-weight: 800;
    margin: 0 0 0.75rem;
  }
  .cta-section p {
    font-size: 1.1rem;
    opacity: 0.9;
    margin: 0 0 1.5rem;
  }
  .cta-actions {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
  }
  .cta-actions a, .cta-actions :global(.whatsapp-btn) {
    padding: 0.85rem 2rem;
    border-radius: 8px;
    font-weight: 600;
    font-size: 1rem;
    text-decoration: none;
    transition: all 0.2s;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
  }
  .btn-primary {
    background: #fff;
    color: #1e3a5f;
  }
  .btn-primary:hover {
    background: #f0f4ff;
    transform: translateY(-1px);
  }
  .cta-actions :global(.whatsapp-btn) {
    background: #25D366;
    color: #fff;
  }
  .cta-actions :global(.whatsapp-btn:hover) {
    background: #20bd5a;
    transform: translateY(-1px);
  }
</style>
